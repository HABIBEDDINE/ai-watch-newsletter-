# ==========================================
# AI Watch Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git (it's in .gitignore)

# ==========================================
# REQUIRED API KEYS - Must have to run the app
# ==========================================

# Get from: https://newsapi.org (free tier available)
# Used to fetch trending technology news articles
NEWS_API_KEY=your_newsapi_key_here

# Get from: https://newsdata.io (free tier available)
# Additional news source for broader coverage
NEWSDATA_API_KEY=pub_c85406a5bbd348e6b61e16b273e29b8b

# ==========================================
# OPTIONAL API KEYS - For enhanced features
# ==========================================

# Get from: https://platform.openai.com/api-keys
# Used for AI article summarization, analysis, and key point extraction
OPENAI_API_KEY=your_openai_api_key_here

# Get from: https://www.perplexity.ai
# Optional: Used for real-time web search and additional article context
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# NOTE: Google News RSS (https://news.google.com/rss) - NO API KEY REQUIRED
# Automatically used for free unlimited news feeds

# ==========================================
# INGESTION SETTINGS
# ==========================================

# Number of articles to fetch per topic (max 20 for free NEWS_API tier)
ARTICLES_PER_TOPIC=20

# Daily ingestion schedule (UTC time, 24-hour format)
# Example: "00:00" = midnight UTC every day
INGEST_SCHEDULE_UTC=00:00

# ==========================================
# AUTH CONFIGURATION
# ==========================================

# Secret key for signing JWT tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-in-production

# Google OAuth (optional — leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL (used in password reset links and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ==========================================
# API & FRONTEND CONFIGURATION
# ==========================================

# Frontend React app API endpoint
REACT_APP_API_URL=http://localhost:8000

# Allowed CORS origins (domains that can call the API)
CORS_ORIGINS=http://localhost:3000

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Backend server host and port
API_HOST=localhost
API_PORT=8000

# ==========================================
# CACHE & PERFORMANCE
# ==========================================

# Cache time-to-live in seconds (3600 = 1 hour)
CACHE_TTL=3600

# Maximum articles to keep in cache
MAX_CACHE_ARTICLES=100

# ==========================================
# OPTIONAL: EMAIL CONFIGURATION
# ==========================================
# Uncomment and fill these in if you want to enable email newsletters

# SMTP server configuration (Gmail example shown)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# NEWSLETTER_EMAIL=recipient@example.com

# ==========================================
# OPTIONAL: LOGGING CONFIGURATION
# ==========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty for console output only)
LOG_FILE=./logs/aiwatch.log

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys (at minimum NEWS_API_KEY)
# 3. Run the project: python api.py (and npm start in another terminal)
# 4. Check http://localhost:8000/docs for API documentation

# ==========================================
# SECURITY NOTES
# ==========================================
# - Never share your API keys
# - Never commit .env to Git
# - Keep API keys in a secure location
# - Use environment variables in production instead of .env files
# - Rotate API keys periodically
